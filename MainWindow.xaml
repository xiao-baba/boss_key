<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="BossKey.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:models="clr-namespace:BossKey.Models"
        Title="老板键"
        Icon="Assets/BossKey.ico"
        Width="960"
        Height="640"
        MinWidth="820"
        MinHeight="560"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI, Segoe UI Variable, Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        Loaded="MainWindow_Loaded"
        SourceInitialized="MainWindow_SourceInitialized"
        Closing="MainWindow_Closing"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <Border Margin="10"
            CornerRadius="18"
            Background="{DynamicResource ChromeBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.14" />
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="168" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    CornerRadius="18,0,0,18"
                    Background="{DynamicResource SidebarBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="46" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                                Margin="16,15,0,0"
                                VerticalAlignment="Top">
                        <Button Style="{StaticResource TrafficButtonStyle}"
                                Background="#FF5F57"
                                ToolTip="关闭到托盘"
                                Tag="×"
                                Click="CloseButton_Click" />
                        <Button Style="{StaticResource TrafficButtonStyle}"
                                Background="#FFBD2E"
                                ToolTip="最小化"
                                Tag="−"
                                Margin="8,0,0,0"
                                Click="MinimizeButton_Click" />
                        <Button Style="{StaticResource TrafficButtonStyle}"
                                Background="#28C840"
                                ToolTip="最大化/还原"
                                Tag="□"
                                Margin="8,0,0,0"
                                Click="MaximizeButton_Click" />
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="老板键"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="20,0,18,13" />
                        <Button x:Name="WindowsNavButton"
                                Content="窗口"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="Selected"
                                Click="WindowsNavButton_Click" />
                        <Button x:Name="RulesNavButton"
                                Content="规则"
                                Style="{StaticResource NavButtonStyle}"
                                Click="RulesNavButton_Click" />
                        <Button x:Name="HotkeysNavButton"
                                Content="快捷键"
                                Style="{StaticResource NavButtonStyle}"
                                Click="HotkeysNavButton_Click" />
                        <Button x:Name="SettingsNavButton"
                                Content="设置"
                                Style="{StaticResource NavButtonStyle}"
                                Click="SettingsNavButton_Click" />
                    </StackPanel>

                    <Border x:Name="SidebarStatusCard"
                            Grid.Row="2"
                            Margin="10,0,10,12"
                            Padding="10,9"
                            CornerRadius="10"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource SoftBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="运行状态"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="11.5" />
                            <TextBlock x:Name="SidebarStatusText"
                                       Text="准备就绪"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"
                                       FontSize="12.5"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1"
                  Margin="16,12,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Background="Transparent"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitleText"
                                   Text="窗口"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="PageSubtitleText"
                                   Text="勾选窗口后隐藏，或使用规则一键隐藏匹配窗口。"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="12.5"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                    <Border x:Name="StatusBadge"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Padding="11,6"
                            CornerRadius="99"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource SoftBorderBrush}"
                            BorderThickness="1">
                        <TextBlock x:Name="StatusBadgeText"
                                   Text="0 个隐藏窗口"
                                   FontSize="12.5"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                    </Border>
                </Grid>

                <Grid x:Name="PagesHost" Grid.Row="1">
                    <Grid x:Name="WindowsPage">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="8"
                                CornerRadius="10"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource SoftBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SearchBox"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         ToolTip="搜索窗口标题、程序名或路径"
                                         TextChanged="SearchBox_TextChanged" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource RoundedButtonStyle}"
                                        Margin="7,0,0,0"
                                        Click="RefreshButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Refresh"
                                                                 Width="15"
                                                                 Height="15"
                                                                 Margin="0,0,5,0"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="刷新" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="7,0,0,0"
                                        Click="HideByRulesButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="EyeOffOutline"
                                                                 Width="15"
                                                                 Height="15"
                                                                 Margin="0,0,5,0"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="按规则隐藏" VerticalAlignment="Center" Foreground="White" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <DataGrid x:Name="WindowsGrid"
                                  Grid.Row="1"
                                  Margin="0,8,0,8"
                                  ItemsSource="{Binding Windows}"
                                  IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header=""
                                                        Width="40"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource CenteredCheckBoxStyle}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="程序"
                                                        Width="112"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource CenteredTextBlockStyle}"
                                                       Text="{Binding ProcessName}"
                                                       ToolTip="{Binding ProcessName}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="窗口标题"
                                                        Width="2.3*"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource CenteredTextBlockStyle}"
                                                       Text="{Binding Title}"
                                                       ToolTip="{Binding Title}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="路径"
                                                        Width="2.1*"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource CenteredTextBlockStyle}"
                                                       Text="{Binding ProcessPath}"
                                                       ToolTip="{Binding ProcessPath}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="PID"
                                                        Width="58"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource CenteredTextBlockStyle}"
                                                       Text="{Binding ProcessId}"
                                                       ToolTip="{Binding ProcessId}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="句柄"
                                                        Width="84"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource CenteredTextBlockStyle}"
                                                       Text="{Binding HandleHex}"
                                                       ToolTip="{Binding HandleHex}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="受限"
                                                        Width="54"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource CenteredCheckBoxStyle}"
                                                      IsChecked="{Binding IsElevatedOrInaccessible}"
                                                      IsHitTestVisible="False" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2"
                                Padding="8"
                                CornerRadius="10"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource SoftBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <TextBlock x:Name="SelectedCountText"
                                           Text="已选择 0 个窗口"
                                           VerticalAlignment="Center"
                                           FontSize="12.5"
                                           Foreground="{DynamicResource MutedTextBrush}" />
                                <WrapPanel HorizontalAlignment="Right">
                                    <Button Style="{StaticResource RoundedButtonStyle}"
                                            Click="SelectAllWindowsButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CheckboxMultipleMarked"
                                                                     Width="15"
                                                                     Height="15"
                                                                     Margin="0,0,5,0"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="全选" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RoundedButtonStyle}"
                                            Margin="7,0,0,0"
                                            Click="ClearSelectedWindowsButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CheckboxBlankOff"
                                                                     Width="15"
                                                                     Height="15"
                                                                     Margin="0,0,5,0"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="清空" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RoundedButtonStyle}"
                                            Margin="7,0,0,0"
                                            Click="CreateRulesFromSelectedButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="TuneVariant"
                                                                     Width="15"
                                                                     Height="15"
                                                                     Margin="0,0,5,0"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="生成规则" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource RoundedButtonStyle}"
                                            Margin="7,0,0,0"
                                            Click="RestoreAllButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Restore"
                                                                     Width="15"
                                                                     Height="15"
                                                                     Margin="0,0,5,0"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="恢复隐藏" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource PrimaryButtonStyle}"
                                            Margin="7,0,0,0"
                                            Click="HideSelectedButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="EyeOff"
                                                                     Width="15"
                                                                     Height="15"
                                                                     Margin="0,0,5,0"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="隐藏选中" VerticalAlignment="Center" Foreground="White" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="RulesPage" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="8"
                                CornerRadius="10"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource SoftBorderBrush}"
                                BorderThickness="1">
                            <WrapPanel>
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Click="AddRuleButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Plus"
                                                                 Width="15"
                                                                 Height="15"
                                                                 Margin="0,0,5,0"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="新建规则" VerticalAlignment="Center" Foreground="White" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource RoundedButtonStyle}"
                                        Margin="7,0,0,0"
                                        Click="AddPathRuleButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ApplicationCog"
                                                                 Width="15"
                                                                 Height="15"
                                                                 Margin="0,0,5,0"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="选择 EXE" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource RoundedButtonStyle}"
                                        Margin="7,0,0,0"
                                        Click="CreateRulesFromSelectedButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="TuneVariant"
                                                                 Width="15"
                                                                 Height="15"
                                                                 Margin="0,0,5,0"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="从选中窗口生成" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource RoundedButtonStyle}"
                                        Margin="7,0,0,0"
                                        Click="DeleteSelectedRulesButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DeleteOutline"
                                                                 Width="15"
                                                                 Height="15"
                                                                 Margin="0,0,5,0"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="删除选中" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource RoundedButtonStyle}"
                                        Margin="7,0,0,0"
                                        Click="SaveRulesButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSaveOutline"
                                                                 Width="15"
                                                                 Height="15"
                                                                 Margin="0,0,5,0"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="保存" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </Border>

                        <DataGrid x:Name="RulesGrid"
                                  Grid.Row="1"
                                  Margin="0,8,0,8"
                                  ItemsSource="{Binding Rules}"
                                  CellEditEnding="RulesGrid_CellEditEnding">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="启用"
                                                        Width="54"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource CenteredCheckBoxStyle}"
                                                      IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="关键词/路径"
                                                        Width="2*"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Pattern, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     TextAlignment="Center"
                                                     VerticalContentAlignment="Center"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     ToolTip="{Binding Pattern}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="匹配"
                                                        Width="110"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.MatchTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedItem="{Binding MatchType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource CenteredComboBoxStyle}"
                                                      BorderThickness="0"
                                                      Background="Transparent" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="标题"
                                                        Width="54"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource CenteredCheckBoxStyle}"
                                                      IsChecked="{Binding MatchTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="程序名"
                                                        Width="64"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource CenteredCheckBoxStyle}"
                                                      IsChecked="{Binding MatchProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="路径"
                                                        Width="54"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource CenteredCheckBoxStyle}"
                                                      IsChecked="{Binding MatchProcessPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="区分大小写"
                                                        Width="88"
                                                        HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                        CellStyle="{StaticResource CenteredCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource CenteredCheckBoxStyle}"
                                                      IsChecked="{Binding CaseSensitive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="2"
                                   Text="规则只会隐藏匹配到的当前可见窗口；恢复时仅恢复本软件隐藏过的窗口。"
                                   FontSize="12.5"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                    </Grid>

                    <Grid x:Name="HotkeysPage" Visibility="Collapsed">
                        <StackPanel>
                            <Border Padding="13,12"
                                    CornerRadius="10"
                                    Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource SoftBorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="隐藏快捷键"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="只隐藏当前勾选窗口；规则隐藏请使用“按规则隐藏”按钮。"
                                                   Margin="0,4,0,0"
                                                   FontSize="12.5"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                    </StackPanel>
                                    <Button x:Name="HideHotkeyButton"
                                            Grid.Column="1"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            MinWidth="138"
                                            Click="HideHotkeyButton_Click" />
                                </Grid>
                            </Border>

                            <Border Padding="13,12"
                                    CornerRadius="10"
                                    Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource SoftBorderBrush}"
                                    BorderThickness="1"
                                    Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="恢复快捷键"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="恢复所有由老板键隐藏的窗口。"
                                                   Margin="0,4,0,0"
                                                   FontSize="12.5"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                    </StackPanel>
                                    <Button x:Name="RestoreHotkeyButton"
                                            Grid.Column="1"
                                            Style="{StaticResource RoundedButtonStyle}"
                                            MinWidth="138"
                                            Click="RestoreHotkeyButton_Click" />
                                </Grid>
                            </Border>

                            <TextBlock x:Name="HotkeyHintText"
                                       Text="点击按钮后按下新的组合键；按 Esc 取消录制。"
                                       Margin="3,14,0,0"
                                       FontSize="12.5"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="SettingsPage" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Padding="13,12"
                                        CornerRadius="10"
                                        Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{DynamicResource SoftBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="外观"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="190" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="主题模式"
                                                       VerticalAlignment="Center"
                                                       FontSize="12.5"
                                                       Foreground="{DynamicResource MutedTextBrush}" />
                                            <ComboBox x:Name="ThemeComboBox"
                                                      Grid.Column="1"
                                                      MinHeight="30"
                                                      SelectionChanged="ThemeComboBox_SelectionChanged">
                                                <ComboBoxItem Content="跟随系统" Tag="System" />
                                                <ComboBoxItem Content="浅色" Tag="Light" />
                                                <ComboBoxItem Content="深色" Tag="Dark" />
                                            </ComboBox>
                                        </Grid>
                                        <CheckBox x:Name="ReduceMotionCheckBox"
                                                  Style="{StaticResource SwitchStyle}"
                                                  Content="减少动画"
                                                  Margin="0,14,0,0"
                                                  Click="ReduceMotionCheckBox_Click" />
                                    </StackPanel>
                                </Border>

                                <Border Padding="13,12"
                                        CornerRadius="10"
                                        Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{DynamicResource SoftBorderBrush}"
                                        BorderThickness="1"
                                        Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="运行方式"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <CheckBox x:Name="StartWithWindowsCheckBox"
                                                  Style="{StaticResource SwitchStyle}"
                                                  Content="开机自启"
                                                  Margin="0,14,0,0"
                                                  Click="StartWithWindowsCheckBox_Click" />
                                        <CheckBox x:Name="AdminHintCheckBox"
                                                  Style="{StaticResource SwitchStyle}"
                                                  Content="遇到权限受限窗口时提示提权"
                                                  Margin="0,9,0,0"
                                                  Click="AdminHintCheckBox_Click" />
                                        <WrapPanel Margin="0,13,0,0">
                                            <Button Content="以管理员身份重启"
                                                    Style="{StaticResource RoundedButtonStyle}"
                                                    Click="RestartAsAdminButton_Click" />
                                            <Button Content="打开配置文件夹"
                                                    Style="{StaticResource RoundedButtonStyle}"
                                                    Margin="8,0,0,0"
                                                    Click="OpenConfigFolderButton_Click" />
                                            <Button Content="退出程序"
                                                    Style="{StaticResource RoundedButtonStyle}"
                                                    Margin="8,0,0,0"
                                                    Click="ExitButton_Click" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="关闭主窗口会进入托盘；退出请使用托盘菜单或设置页按钮。"
                                           Margin="3,14,0,0"
                                           FontSize="12.5"
                                           Foreground="{DynamicResource MutedTextBrush}" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
